---
import '../styles/global.css';
import HeaderIsland from '../components/islands/HeaderIsland';
import Footer from '../components/Footer.astro';
import CookieConsentIsland from '../components/islands/CookieConsentIsland';

interface Props {
  title: string;
  description: string;
  keywords?: string;
  ogImage?: string;
  ogType?: string;
}

const { title, description, keywords = '', ogImage, ogType = 'website' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const currentPath = Astro.url.pathname;
const GA_ID = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {keywords && <meta name="keywords" content={keywords} />}
  <link rel="canonical" href={canonicalURL} />

  <!-- OG Tags -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content="Amit Srivatsa" />
  {ogImage && <meta property="og:image" content={ogImage} />}

  <!-- Twitter Cards -->
  <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  {ogImage && <meta name="twitter:image" content={ogImage} />}

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebSite",
        "@id": "https://amitsrivatsa.com/#website",
        "url": "https://amitsrivatsa.com/",
        "name": "Amit Srivatsa",
        "description": "Personal website of Amit Srivatsa, an AI and marketing consultant helping B2B teams build clarity, better decisions, and scalable systems.",
        "inLanguage": "en",
        "publisher": { "@id": "https://amitsrivatsa.com/#person" },
        "keywords": ["AI consultant", "AI in marketing", "AI adoption", "marketing strategy", "B2B marketing", "content systems", "workflow automation", "AI workflows", "AI for small teams", "AI strategy consultant", "decision making systems", "Netherlands"]
      },
      {
        "@type": "Person",
        "@id": "https://amitsrivatsa.com/#person",
        "name": "Amit Srivatsa",
        "url": "https://amitsrivatsa.com/",
        "jobTitle": "AI & marketing consultant",
        "description": "AI and marketing consultant focused on responsible AI adoption, content systems, and decision-making frameworks for B2B teams.",
        "sameAs": ["https://www.linkedin.com/in/amit-srivatsa/"],
        "knowsAbout": ["AI adoption", "AI in marketing", "workflow automation", "content strategy", "B2B growth", "systems thinking", "responsible AI"],
        "areaServed": [
          { "@type": "Country", "name": "Netherlands" },
          { "@type": "AdministrativeArea", "name": "European Union" }
        ]
      }
    ]
  })} />

  <!-- Google Analytics 4 with Consent Mode v2 -->
  {GA_ID && (
    <>
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
      <script is:inline define:vars={{ GA_ID }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('consent', 'default', { analytics_storage: 'denied' });
        gtag('js', new Date());
        gtag('config', GA_ID);
        if (typeof localStorage !== 'undefined' && localStorage.getItem('cookieConsent') === 'granted') {
          gtag('consent', 'update', { analytics_storage: 'granted' });
        }
      </script>
    </>
  )}

  <!-- Hash route redirect for backwards compatibility -->
  <script is:inline>
    if (window.location.hash.startsWith('#/')) {
      window.location.replace(window.location.hash.slice(1));
    }
  </script>
</head>
<body class="min-h-screen flex flex-col bg-white selection:bg-orange-200 selection:text-orange-900">
  <div class="print:hidden">
    <HeaderIsland currentPath={currentPath} client:load />
  </div>
  <main class="flex-grow">
    <slot />
  </main>
  <div class="print:hidden">
    <Footer />
  </div>
  <CookieConsentIsland client:load />
</body>
</html>
