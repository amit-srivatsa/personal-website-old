---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterIsland from '../components/islands/NewsletterIsland';
---
<BaseLayout title="Amit Srivatsa - AI Strategy, Content Systems & Marketing for B2B Teams" description="I build practical AI, content, and marketing systems for B2B teams. Work with me to design simple, repeatable systems that compound over time." keywords="AI strategy, content marketing, B2B marketing, marketing systems, AI consultant, Amit Srivatsa">

  <!-- Hero Section -->
  <section class="relative bg-white overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 sm:px-8 pt-32 pb-8 lg:pt-48 lg:pb-12">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
        <div class="w-full lg:w-1/2 z-10">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white border border-gray-200 shadow-sm mb-8">
            <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
            <span class="text-xs font-bold uppercase tracking-wide text-gray-600">Available for new projects</span>
          </div>
          <h1 class="text-5xl md:text-7xl font-bold tracking-tight text-gray-900 leading-[1.05] mb-6">
            Hi, I'm Amit! <br />
          </h1>
          <p class="text-xl text-gray-600 font-medium leading-relaxed max-w-xl mb-6">
            I build practical AI, content, and marketing systems for B2B teams.
          </p>
          <p class="text-base text-gray-500 leading-relaxed max-w-xl mb-10">
            I work with founders and small teams to design simple, repeatable systems using AI, content, and strategy. Systems that compound over time and don't collapse when the ads stop.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="https://calendar.app.google/jcY3JgK9YACJ3SA5A" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center font-bold text-white bg-black rounded-full border border-transparent hover:bg-gray-800 transition-all duration-200 hover:scale-105 shadow-sm group px-8 py-4 text-base">
              Book a free consultation
            </a>
            <a href="/services" class="inline-flex items-center justify-center px-8 py-4 text-base font-bold text-gray-900 bg-white border border-gray-200 rounded-full hover:bg-gray-50 transition-all duration-200 hover:scale-105 shadow-sm group">
              See how this works
            </a>
          </div>
        </div>
        <div class="w-full lg:w-1/2 relative mt-8 lg:mt-0">
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] bg-gradient-to-tr from-orange-200/40 via-pink-200/40 to-blue-200/40 rounded-full blur-3xl opacity-70"></div>
          <div class="relative rounded-[2.5rem] overflow-hidden shadow-2xl rotate-2 hover:rotate-0 transition-transform duration-700 ease-out bg-gray-200">
            <img src="https://ik.imagekit.io/mws/main-site/amit-photo-1.jpg" alt="Amit Srivatsa" class="w-full h-auto object-cover scale-105" loading="eager" />
            <div class="absolute bottom-8 left-8 bg-white/90 backdrop-blur-md p-4 rounded-2xl shadow-lg border border-white/20 max-w-[240px]">
              <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Focus</p>
              <p class="text-sm font-bold text-gray-900">AI strategy, content systems, and smart automation</p>
            </div>
          </div>
        </div>
      </div>
      <div class="mt-16 pt-8 border-t border-gray-200/60">
        <p class="text-center text-sm font-semibold text-gray-400 uppercase tracking-widest mb-8">
          I've built Content Strategy pipelines for Fortune 100 companies
        </p>
        <div class="flex flex-wrap justify-center items-center gap-12 transition-all duration-500">
          <img src="https://www.adobe.com/federal/assets/svgs/adobe-logo.svg" alt="Adobe" class="h-10 max-w-[120px] w-auto object-contain" />
          <img src="https://upload.wikimedia.org/wikipedia/commons/e/e4/NetApp_%282020%29.svg" alt="NetApp" class="h-7 max-w-[130px] w-auto object-contain" />
        </div>
      </div>
    </div>
  </section>

  <!-- About Preview Section -->
  <section class="py-24 bg-white relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 sm:px-8">
      <div class="flex flex-col lg:flex-row items-center gap-16 lg:gap-24">

        <!-- Image Side -->
        <div class="w-full lg:w-1/2 relative">
          <div class="aspect-[4/5] rounded-[2.5rem] overflow-hidden bg-gray-100 shadow-2xl relative z-10">
            <img
              src="https://ik.imagekit.io/mws/main-site/amit-photo-2.jpeg"
              alt="Amit Srivatsa Portrait"
              class="w-full h-full object-cover"
            />
          </div>
          <!-- Decorative Elements -->
          <div class="absolute -bottom-12 -right-12 w-64 h-64 bg-purple-50 rounded-full blur-3xl -z-10"></div>
          <div class="absolute -top-12 -left-12 w-64 h-64 bg-blue-50 rounded-full blur-3xl -z-10"></div>
        </div>

        <!-- Content Side -->
        <div class="w-full lg:w-1/2">
          <div class="inline-flex items-center gap-2 mb-6">
            <span class="w-8 h-[2px] bg-black"></span>
            <span class="text-sm font-semibold text-gray-500 uppercase tracking-widest">about me</span>
          </div>

          <h2 class="text-4xl sm:text-5xl font-bold tracking-tight text-gray-900 mb-6 leading-[1.1]">
            I am a <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-600 to-red-600">strategic partner</span> for clarity and growth.
          </h2>

          <div class="text-lg text-gray-600 leading-relaxed mb-8 space-y-4">
            <p>
              Most business decisions don't fail because of lack of effort. They fail because the thinking underneath is fuzzy.
            </p>
            <p>
              I work with founders and small B2B teams who are overwhelmed by options. I help you slow down, choose wisely, and build systems that actually move the needle.
            </p>
            <p>
              I translate enterprise-level strategy into practical actions. Then I help you execute without burning out your team.
            </p>
          </div>

          <!-- Stats Grid -->
          <div class="grid grid-cols-2 gap-8 mb-10 border-y border-gray-100 py-8">
            <div>
              <p class="text-4xl font-bold text-gray-900 mb-1">8+</p>
              <p class="text-sm font-medium text-gray-500 uppercase tracking-wide">years of experience</p>
              <p class="text-xs text-gray-400 mt-1">Across B2B, content, and digital strategy</p>
            </div>
            <div>
              <p class="text-4xl font-bold text-gray-900 mb-1">3</p>
              <p class="text-sm font-medium text-gray-500 uppercase tracking-wide">startups founded</p>
              <p class="text-xs text-gray-400 mt-1">Bootstrapped, learned the hard way, still standing</p>
            </div>
          </div>

          <a
            href="/cv"
            class="inline-flex items-center text-base font-bold text-black hover:text-orange-600 transition-colors group"
          >
            Read my full story
            <svg class="ml-2 w-5 h-5 transition-transform group-hover:translate-x-1" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- Bento Grid / Services Section -->
  <section class="py-24 bg-gray-50" id="services">
    <div class="max-w-7xl mx-auto px-6 sm:px-8">

      <div class="flex flex-col md:flex-row md:items-end justify-between mb-16">
        <div class="max-w-2xl">
          <h2 class="text-sm font-bold text-orange-600 uppercase tracking-widest mb-3">
            grow
          </h2>
          <h3 class="text-4xl md:text-5xl font-bold tracking-tight text-gray-900 leading-tight">
            Here's how I help you.
          </h3>
          <div class="mt-4 text-xl text-gray-500 max-w-lg space-y-2">
            <p>I work with people at different stages. The work looks different, but the goal is the same. Clarity.</p>
            <p class="text-base">I don't sell motivation or vague advice. I help you make better decisions and build systems that hold up in the real world.</p>
          </div>
        </div>

        <div class="mt-8 md:mt-0">
          <a
            href="/services"
            class="inline-flex items-center px-6 py-3 border border-gray-300 rounded-full text-sm font-bold text-gray-900 hover:bg-black hover:text-white hover:border-black transition-all"
          >
            View all services
          </a>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

        <!-- Card 1 -->
        <a href="/contact" class="group block h-full">
          <div class="bg-white rounded-[2rem] p-4 pb-8 h-full shadow-sm border border-gray-100 transition-all duration-300 hover:shadow-xl hover:-translate-y-1 flex flex-col">
            <div class="aspect-[4/3] rounded-[1.5rem] overflow-hidden mb-6 bg-gray-100">
              <img
                src="https://images.unsplash.com/photo-1552664730-d307ca884978?q=80&w=2070&auto=format&fit=crop"
                alt="Strategic consulting"
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              />
            </div>
            <div class="px-4 flex-grow">
              <h4 class="text-2xl font-bold text-gray-900 mb-1 leading-tight group-hover:text-orange-600 transition-colors">
                Strategic consulting
              </h4>
              <p class="text-sm font-semibold text-gray-400 mb-3">(for businesses)</p>
              <p class="text-base text-gray-500 leading-relaxed">
                These are not coaching calls. They are focused thinking sessions. We work through your actual problems together. Positioning, priorities, AI adoption, content, or growth strategy. You leave every session with clarity and next steps. Fewer options. Better decisions.
              </p>
            </div>
          </div>
        </a>

        <!-- Card 2 -->
        <a href="/services" class="group block h-full">
          <div class="bg-white rounded-[2rem] p-4 pb-8 h-full shadow-sm border border-gray-100 transition-all duration-300 hover:shadow-xl hover:-translate-y-1 flex flex-col">
            <div class="aspect-[4/3] rounded-[1.5rem] overflow-hidden mb-6 bg-gray-100">
              <img
                src="https://images.unsplash.com/photo-1531403009284-440f080d1e12?q=80&w=2070&auto=format&fit=crop"
                alt="Personalised growth roadmap"
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              />
            </div>
            <div class="px-4 flex-grow">
              <h4 class="text-2xl font-bold text-gray-900 mb-1 leading-tight group-hover:text-orange-600 transition-colors">
                Personalised growth roadmap
              </h4>
              <p class="text-base text-gray-500 leading-relaxed">
                You get a clear plan. Not a 40-slide deck. We map where you are. We define where you want to go. Then we design a simple path to get there. The goal is momentum. Not perfection.
              </p>
            </div>
          </div>
        </a>

        <!-- Card 3 -->
        <a href="/services" class="group block h-full">
          <div class="bg-white rounded-[2rem] p-4 pb-8 h-full shadow-sm border border-gray-100 transition-all duration-300 hover:shadow-xl hover:-translate-y-1 flex flex-col">
            <div class="aspect-[4/3] rounded-[1.5rem] overflow-hidden mb-6 bg-gray-100">
              <img
                src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?q=80&w=2070&auto=format&fit=crop"
                alt="Tools & systems"
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              />
            </div>
            <div class="px-4 flex-grow">
              <h4 class="text-2xl font-bold text-gray-900 mb-1 leading-tight group-hover:text-orange-600 transition-colors">
                Tools & systems
              </h4>
              <p class="text-sm font-semibold text-gray-400 mb-3">(for builders)</p>
              <p class="text-base text-gray-500 leading-relaxed">
                Good ideas fail without systems. I help you design lightweight frameworks and shared tools. For decision-making, execution, and focus. These systems are designed to compound over time. And to be used when things get busy.
              </p>
            </div>
          </div>
        </a>

      </div>

      <!-- Navigation Arrows -->
      <div class="flex justify-center gap-4 mt-12">
        <button class="p-3 rounded-full border border-gray-200 text-gray-400 hover:text-black hover:border-black transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="rotate-[-135deg]"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
        </button>
        <button class="p-3 rounded-full bg-black text-white hover:bg-gray-800 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="rotate-45"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
        </button>
      </div>

    </div>
  </section>

  <!-- Newsletter Section -->
  <NewsletterIsland client:visible />

</BaseLayout>
