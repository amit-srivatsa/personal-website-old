---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterIsland from '../components/islands/NewsletterIsland';
---
<BaseLayout title="Amit Srivatsa - AI Strategy, Content Systems & Marketing for B2B Teams" description="I build practical AI, content, and marketing systems for B2B teams. Work with me to design simple, repeatable systems that compound over time." keywords="AI strategy, content marketing, B2B marketing, marketing systems, AI consultant, Amit Srivatsa">

  <!-- Hero Section -->
  <section class="relative bg-white overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 sm:px-8 pt-32 pb-8 lg:pt-48 lg:pb-12">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">

        <!-- Mobile-only: badge + h1 shown above the image -->
        <div class="w-full lg:hidden z-10">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white border border-gray-200 shadow-sm mb-8">
            <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
            <span class="text-xs font-bold uppercase tracking-wide text-gray-600">Available for new projects</span>
          </div>
          <h1 class="text-5xl font-bold tracking-tight text-gray-900 leading-[1.05] mb-0">
            Hi, I'm Amit!
          </h1>
        </div>

        <!-- Image: 2nd on mobile, right column on desktop -->
        <div class="w-full lg:w-1/2 relative mt-0 lg:mt-0 lg:order-2">
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] bg-gradient-to-tr from-orange-200/40 via-pink-200/40 to-blue-200/40 rounded-full blur-3xl opacity-70"></div>
          <div class="relative rounded-[2.5rem] overflow-hidden shadow-2xl rotate-2 hover:rotate-0 transition-transform duration-700 ease-out bg-gray-200">
            <img src="https://ik.imagekit.io/mws/main-site/amit-photo-1.jpg" alt="Amit Srivatsa" class="w-full h-auto object-cover scale-105" loading="eager" />
            <div class="absolute bottom-8 left-8 bg-white/90 backdrop-blur-md p-4 rounded-2xl shadow-lg border border-white/20 max-w-[240px]">
              <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Focus</p>
              <p class="text-sm font-bold text-gray-900">AI strategy, content systems, and smart automation</p>
            </div>
          </div>
        </div>

        <!-- Left column: full on desktop, paragraphs + CTAs only on mobile -->
        <div class="w-full lg:w-1/2 z-10 lg:order-1">
          <!-- Desktop-only: badge + h1 (shown above image on mobile via the block above) -->
          <div class="hidden lg:block">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white border border-gray-200 shadow-sm mb-8">
              <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
              <span class="text-xs font-bold uppercase tracking-wide text-gray-600">Available for new projects</span>
            </div>
            <h1 class="text-5xl md:text-7xl font-bold tracking-tight text-gray-900 leading-[1.05] mb-6">
              Hi, I'm Amit! <br />
            </h1>
          </div>
          <p class="text-xl text-gray-600 font-medium leading-relaxed max-w-xl mb-6 mt-6 lg:mt-0">
            I build practical AI, content, and marketing systems for B2B teams.
          </p>
          <p class="text-base text-gray-500 leading-relaxed max-w-xl mb-10">
            I work with founders and small teams to design simple, repeatable systems using AI, content, and strategy. Systems that compound over time and don't collapse when the ads stop.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="https://calendar.app.google/jcY3JgK9YACJ3SA5A" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center font-bold text-white bg-black rounded-full border border-transparent hover:bg-gray-800 transition-all duration-200 hover:scale-105 shadow-sm group px-8 py-4 text-base">
              Book a free consultation
            </a>
            <a href="/services" class="inline-flex items-center justify-center px-8 py-4 text-base font-bold text-gray-900 bg-white border border-gray-200 rounded-full hover:bg-gray-50 transition-all duration-200 hover:scale-105 shadow-sm group">
              See how this works
            </a>
          </div>
        </div>

      </div>
      <div class="mt-16 pt-8 border-t border-gray-200/60">
        <p class="text-center text-sm font-semibold text-gray-400 uppercase tracking-widest mb-8">
          I've built Content Strategy pipelines for Fortune 100 companies
        </p>
        <div class="flex flex-wrap justify-center items-center gap-12 transition-all duration-500">
          <img src="https://www.adobe.com/federal/assets/svgs/adobe-logo.svg" alt="Adobe" class="h-10 max-w-[120px] w-auto object-contain" />
          <img src="https://upload.wikimedia.org/wikipedia/commons/e/e4/NetApp_%282020%29.svg" alt="NetApp" class="h-7 max-w-[130px] w-auto object-contain" />
        </div>
      </div>
    </div>
  </section>

  <!-- About Preview Section -->
  <section class="py-24 bg-white relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 sm:px-8">
      <div class="flex flex-col lg:flex-row items-center gap-16 lg:gap-24">

        <!-- Image Side -->
        <div class="w-full lg:w-1/2 relative">
          <div class="aspect-[4/5] rounded-[2.5rem] overflow-hidden bg-gray-100 shadow-2xl relative z-10">
            <img
              src="https://ik.imagekit.io/mws/main-site/amit-photo-3.jpg"
              alt="Amit Srivatsa Portrait"
              class="w-full h-full object-cover"
            />
          </div>
          <!-- Decorative Elements -->
          <div class="absolute -bottom-12 -right-12 w-64 h-64 bg-purple-50 rounded-full blur-3xl -z-10"></div>
          <div class="absolute -top-12 -left-12 w-64 h-64 bg-blue-50 rounded-full blur-3xl -z-10"></div>
        </div>

        <!-- Content Side -->
        <div class="w-full lg:w-1/2">
          <div class="inline-flex items-center gap-2 mb-6">
            <span class="w-8 h-[2px] bg-black"></span>
            <span class="text-sm font-semibold text-gray-500 uppercase tracking-widest">about me</span>
          </div>

          <h2 class="text-4xl sm:text-5xl font-bold tracking-tight text-gray-900 mb-6 leading-[1.1]">
            I am a <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-600 to-red-600">strategic partner</span> for clarity and growth.
          </h2>

          <div class="text-lg text-gray-600 leading-relaxed mb-8 space-y-4">
            <p>
              Most business decisions don't fail because of lack of effort. They fail because the thinking underneath is fuzzy.
            </p>
            <p>
              I work with founders and small B2B teams who are overwhelmed by options. I help you slow down, choose wisely, and build systems that actually move the needle.
            </p>
            <p>
              I translate enterprise-level strategy into practical actions. Then I help you execute without burning out your team.
            </p>
          </div>

          <!-- Stats Grid -->
          <div class="grid grid-cols-2 gap-8 mb-10 border-y border-gray-100 py-8">
            <div>
              <p class="text-4xl font-bold text-gray-900 mb-1">8+</p>
              <p class="text-sm font-medium text-gray-500 uppercase tracking-wide">years of experience</p>
              <p class="text-xs text-gray-400 mt-1">Across B2B, content, and digital strategy</p>
            </div>
            <div>
              <p class="text-4xl font-bold text-gray-900 mb-1">3</p>
              <p class="text-sm font-medium text-gray-500 uppercase tracking-wide">startups founded</p>
              <p class="text-xs text-gray-400 mt-1">Bootstrapped, learned the hard way, still standing</p>
            </div>
          </div>

          <a
            href="/cv"
            class="inline-flex items-center text-base font-bold text-black hover:text-orange-600 transition-colors group"
          >
            Read my full story
            <svg class="ml-2 w-5 h-5 transition-transform group-hover:translate-x-1" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- Bento Grid / Services Section -->
  <section class="py-24 bg-gray-50" id="services">
    <div class="max-w-7xl mx-auto px-6 sm:px-8">

      <div class="flex flex-col md:flex-row md:items-end justify-between mb-16">
        <div class="max-w-2xl">
          <h2 class="text-sm font-bold text-orange-600 uppercase tracking-widest mb-3">
            grow
          </h2>
          <h3 class="text-4xl md:text-5xl font-bold tracking-tight text-gray-900 leading-tight">
            Here's how I help you.
          </h3>
          <div class="mt-4 text-xl text-gray-500 max-w-lg space-y-2">
            <p>I work with people at different stages. The work looks different, but the goal is the same. Clarity.</p>
            <p class="text-base">I don't sell motivation or vague advice. I help you make better decisions and build systems that hold up in the real world.</p>
          </div>
        </div>

        <div class="mt-8 md:mt-0">
          <a
            href="/services"
            class="inline-flex items-center px-6 py-3 border border-gray-300 rounded-full text-sm font-bold text-gray-900 hover:bg-black hover:text-white hover:border-black transition-all"
          >
            View all services
          </a>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

        <!-- Card 1 -->
        <a href="/contact" class="group block h-full">
          <div class="bg-white rounded-[2rem] p-4 pb-8 h-full shadow-sm border border-gray-100 transition-all duration-300 hover:shadow-xl hover:-translate-y-1 flex flex-col">
            <div class="aspect-[4/3] rounded-[1.5rem] overflow-hidden mb-6 relative flex items-center justify-center" style="background: linear-gradient(145deg, #F5F3FF, #EDE9FE);">
              <div class="relative w-[80%]" style="height: 72%;">
                <!-- Card 3 - background, faded — sky blue -->
                <div class="absolute consulting-card-3 rounded-2xl px-4 py-3 shadow-sm" style="top: 54%; left: 12%; width: 74%; opacity: 0.6; z-index: 1; background: #F0F9FF; border: 1px solid #BAE6FD;">
                  <div class="flex items-center gap-2 mb-2">
                    <span class="w-1.5 h-1.5 rounded-full" style="background:#0EA5E9;"></span>
                    <span class="text-[10px] font-bold uppercase tracking-wider" style="color:#0EA5E9;">AI Tools</span>
                  </div>
                  <div class="h-1.5 rounded-full w-3/4 mb-1" style="background:#BAE6FD;"></div>
                  <div class="h-1.5 rounded-full w-1/2" style="background:#E0F2FE;"></div>
                </div>
                <!-- Card 2 - middle — indigo -->
                <div class="absolute consulting-card-2 rounded-2xl px-4 py-3 shadow-sm" style="top: 27%; right: 0; width: 74%; z-index: 2; background: #EEF2FF; border: 1px solid #C7D2FE;">
                  <div class="flex items-center gap-2 mb-2">
                    <span class="w-1.5 h-1.5 rounded-full" style="background:#6366F1;"></span>
                    <span class="text-[10px] font-bold uppercase tracking-wider" style="color:#6366F1;">Content plan</span>
                  </div>
                  <div class="h-1.5 rounded-full w-full mb-1" style="background:#C7D2FE;"></div>
                  <div class="h-1.5 rounded-full w-2/3" style="background:#E0E7FF;"></div>
                </div>
                <!-- Card 1 - front, violet/priority -->
                <div class="absolute consulting-card-1 rounded-2xl px-4 py-3 shadow-lg" style="top: 0; left: 0; width: 74%; z-index: 3; background: #F5F3FF; border: 1px solid #C4B5FD;">
                  <div class="flex items-center gap-2 mb-2">
                    <span class="w-1.5 h-1.5 rounded-full" style="background:#7C3AED;"></span>
                    <span class="text-[10px] font-bold uppercase tracking-wider" style="color:#7C3AED;">Positioning</span>
                  </div>
                  <div class="h-1.5 rounded-full w-4/5 mb-1" style="background:#C4B5FD;"></div>
                  <div class="h-1.5 rounded-full w-3/5" style="background:#DDD6FE;"></div>
                </div>
              </div>
            </div>
            <div class="px-4 flex-grow">
              <h4 class="text-2xl font-bold text-gray-900 mb-1 leading-tight group-hover:text-orange-600 transition-colors">
                Strategic consulting
              </h4>
              <p class="text-sm font-semibold text-gray-400 mb-3">(for businesses)</p>
              <p class="text-base text-gray-500 leading-relaxed">
                These are not coaching calls. They are focused thinking sessions. We work through your actual problems together. Positioning, priorities, AI adoption, content, or growth strategy. You leave every session with clarity and next steps. Fewer options. Better decisions.
              </p>
            </div>
          </div>
        </a>

        <!-- Card 2 -->
        <a href="/services" class="group block h-full">
          <div class="bg-white rounded-[2rem] p-4 pb-8 h-full shadow-sm border border-gray-100 transition-all duration-300 hover:shadow-xl hover:-translate-y-1 flex flex-col">
            <div class="aspect-[4/3] rounded-[1.5rem] overflow-hidden mb-6 relative flex items-center justify-center" style="background: linear-gradient(145deg, #ECFDF5, #D1FAE5);">
              <div class="w-[82%]">
                <!-- Milestone track -->
                <div class="relative flex items-start justify-between mb-6">
                  <!-- Track line background -->
                  <div class="absolute left-2 right-2" style="top: 7px; height: 2px; background: #A7F3D0;"></div>
                  <!-- Animated progress fill -->
                  <div class="roadmap-progress absolute left-2" style="top: 7px; height: 2px; background: #059669;"></div>
                  <!-- Node 1: Now -->
                  <div class="relative flex flex-col items-center gap-1.5 z-10">
                    <div class="w-3.5 h-3.5 rounded-full border-2 border-white shadow-sm roadmap-pulse" style="background:#059669;"></div>
                    <span class="text-[9px] font-bold whitespace-nowrap" style="color:#059669;">Now</span>
                  </div>
                  <!-- Node 2: Plan -->
                  <div class="relative flex flex-col items-center gap-1.5 z-10">
                    <div class="roadmap-node-2 w-3.5 h-3.5 rounded-full border-2 border-white shadow-sm"></div>
                    <span class="text-[9px] font-semibold text-gray-500 whitespace-nowrap">Plan</span>
                  </div>
                  <!-- Node 3: Build -->
                  <div class="relative flex flex-col items-center gap-1.5 z-10">
                    <div class="roadmap-node-3 w-3.5 h-3.5 rounded-full border-2 border-white shadow-sm" style="background:#A7F3D0;"></div>
                    <span class="text-[9px] font-semibold text-gray-500 whitespace-nowrap">Build</span>
                  </div>
                  <!-- Node 4: Goal -->
                  <div class="relative flex flex-col items-center gap-1.5 z-10">
                    <div class="w-3.5 h-3.5 rounded-full border-2 border-dashed bg-white shadow-sm" style="border-color:#6EE7B7;"></div>
                    <span class="text-[9px] font-semibold text-gray-500 whitespace-nowrap">Goal</span>
                  </div>
                </div>
                <!-- Step cards -->
                <div class="space-y-2">
                  <div class="rounded-xl px-3 py-2.5 flex items-center gap-3" style="background:#F0FDF4; border: 1px solid #A7F3D0;">
                    <span class="w-5 h-5 rounded-full flex items-center justify-center text-[9px] font-bold text-white flex-shrink-0" style="background:#059669;">1</span>
                    <div class="flex-grow">
                      <div class="h-1.5 rounded-full w-28 mb-1" style="background:#6EE7B7;"></div>
                      <div class="h-1.5 rounded-full w-20" style="background:#A7F3D0;"></div>
                    </div>
                  </div>
                  <div class="bg-white rounded-xl px-3 py-2.5 flex items-center gap-3" style="opacity: 0.6; border: 1px solid #E5E7EB;">
                    <span class="w-5 h-5 rounded-full bg-gray-200 flex items-center justify-center text-[9px] font-bold text-gray-400 flex-shrink-0">2</span>
                    <div class="flex-grow">
                      <div class="h-1.5 bg-gray-200 rounded-full w-24 mb-1"></div>
                      <div class="h-1.5 bg-gray-100 rounded-full w-16"></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div class="px-4 flex-grow">
              <h4 class="text-2xl font-bold text-gray-900 mb-1 leading-tight group-hover:text-orange-600 transition-colors">
                Personalised growth roadmap
              </h4>
              <p class="text-base text-gray-500 leading-relaxed">
                You get a clear plan. Not a 40-slide deck. We map where you are. We define where you want to go. Then we design a simple path to get there. The goal is momentum. Not perfection.
              </p>
            </div>
          </div>
        </a>

        <!-- Card 3 -->
        <a href="/services" class="group block h-full">
          <div class="bg-white rounded-[2rem] p-4 pb-8 h-full shadow-sm border border-gray-100 transition-all duration-300 hover:shadow-xl hover:-translate-y-1 flex flex-col">
            <div class="aspect-[4/3] rounded-[1.5rem] overflow-hidden mb-6 relative flex items-center justify-center" style="background: linear-gradient(145deg, #EFF6FF, #DBEAFE);">
              <div class="w-[82%] space-y-0">
                <!-- Layer 1 - Decision (indigo/violet) -->
                <div class="systems-layer-1 bg-white rounded-2xl px-4 py-3 shadow-sm flex items-center gap-3" style="border: 1px solid #C7D2FE;">
                  <div class="w-8 h-8 rounded-xl flex-shrink-0 flex items-center justify-center" style="background:#EEF2FF;">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect x="1" y="1" width="5" height="5" rx="1" fill="#4F46E5"/><rect x="8" y="1" width="5" height="5" rx="1" fill="#4F46E5" opacity="0.5"/><rect x="1" y="8" width="5" height="5" rx="1" fill="#4F46E5" opacity="0.5"/><rect x="8" y="8" width="5" height="5" rx="1" fill="#4F46E5" opacity="0.2"/></svg>
                  </div>
                  <div class="flex-grow">
                    <div class="text-[11px] font-bold text-gray-800 mb-1">Decision framework</div>
                    <div class="h-1 rounded-full w-3/4" style="background:#C7D2FE;"></div>
                  </div>
                  <div class="w-5 h-5 rounded-full flex-shrink-0 flex items-center justify-center" style="background:#4F46E5;">
                    <svg width="9" height="9" viewBox="0 0 9 9" fill="none"><path d="M1.5 4.5L3.5 6.5L7.5 2.5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </div>
                </div>
                <!-- Connector -->
                <div class="flex justify-center">
                  <div class="systems-connector w-0.5" style="height: 10px; background:#BFDBFE;"></div>
                </div>
                <!-- Layer 2 - Execution (vivid blue) -->
                <div class="systems-layer-2 bg-white rounded-2xl px-4 py-3 shadow-sm flex items-center gap-3" style="border: 1px solid #BAE6FD;">
                  <div class="w-8 h-8 rounded-xl flex-shrink-0 flex items-center justify-center" style="background:#F0F9FF;">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="5.5" stroke="#0EA5E9" stroke-width="1.5" fill="none" stroke-dasharray="3 2"/></svg>
                  </div>
                  <div class="flex-grow">
                    <div class="text-[11px] font-bold text-gray-800 mb-1">Execution system</div>
                    <div class="h-1 rounded-full w-1/2 execution-bar" style="background:#7DD3FC;"></div>
                  </div>
                  <div class="w-5 h-5 rounded-full border-2 flex-shrink-0" style="border-color:#7DD3FC;"></div>
                </div>
                <!-- Connector -->
                <div class="flex justify-center">
                  <div class="systems-connector w-0.5" style="height: 10px; background:#BFDBFE;"></div>
                </div>
                <!-- Layer 3 - Focus (pink/rose, pending) -->
                <div class="systems-layer-3 bg-white rounded-2xl px-4 py-3 shadow-sm flex items-center gap-3" style="opacity: 0.6; border: 1px solid #FBCFE8;">
                  <div class="w-8 h-8 rounded-xl flex-shrink-0 flex items-center justify-center" style="background:#FDF2F8;">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 2C7 2 3 5 3 8C3 10.2 4.8 12 7 12C9.2 12 11 10.2 11 8C11 5 7 2 7 2Z" stroke="#EC4899" stroke-width="1.2" fill="none"/></svg>
                  </div>
                  <div class="flex-grow">
                    <div class="text-[11px] font-bold mb-1" style="color:#9CA3AF;">Focus protocol</div>
                    <div class="h-1 rounded-full w-2/5" style="background:#FBCFE8;"></div>
                  </div>
                  <div class="w-5 h-5 rounded-full border-2 flex-shrink-0" style="border-color:#FBCFE8;"></div>
                </div>
              </div>
            </div>
            <div class="px-4 flex-grow">
              <h4 class="text-2xl font-bold text-gray-900 mb-1 leading-tight group-hover:text-orange-600 transition-colors">
                Tools & systems
              </h4>
              <p class="text-sm font-semibold text-gray-400 mb-3">(for builders)</p>
              <p class="text-base text-gray-500 leading-relaxed">
                Good ideas fail without systems. I help you design lightweight frameworks and shared tools. For decision-making, execution, and focus. These systems are designed to compound over time. And to be used when things get busy.
              </p>
            </div>
          </div>
        </a>

      </div>

    </div>
  </section>

  <!-- Newsletter Section -->
  <NewsletterIsland client:visible />

</BaseLayout>

<style is:global>
  /* Card 1 - Strategic Consulting: staggered float with scale on primary card */
  @keyframes card-float {
    0%, 100% { transform: translateY(0px) scale(1); }
    50%      { transform: translateY(-11px) scale(1.02); }
  }
  @keyframes card-float-mid {
    0%, 100% { transform: translateY(0px); }
    50%      { transform: translateY(-8px); }
  }
  @keyframes card-float-back {
    0%, 100% { transform: translateY(0px); }
    50%      { transform: translateY(-5px); }
  }
  .consulting-card-1 { animation: card-float 3s cubic-bezier(0.45, 0, 0.55, 1) infinite; }
  .consulting-card-2 { animation: card-float-mid 4s cubic-bezier(0.45, 0, 0.55, 1) infinite 0.7s; }
  .consulting-card-3 { animation: card-float-back 5s cubic-bezier(0.45, 0, 0.55, 1) infinite 1.4s; }

  /* Card 2 - Growth Roadmap: snappy progress fill */
  @keyframes roadmap-fill {
    0%   { width: 0%; }
    35%  { width: 42%; }
    65%  { width: 42%; }
    100% { width: 0%; }
  }
  .roadmap-progress { animation: roadmap-fill 2.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) infinite; }

  @keyframes roadmap-node-fade {
    0%, 25%  { background: #A7F3D0; }
    40%, 70% { background: #059669; }
    85%, 100%{ background: #A7F3D0; }
  }
  .roadmap-node-2 { animation: roadmap-node-fade 2.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) infinite; }

  @keyframes roadmap-node3-fade {
    0%, 50%  { background: #A7F3D0; }
    65%, 85% { background: #059669; }
    100%     { background: #A7F3D0; }
  }
  .roadmap-node-3 { animation: roadmap-node3-fade 2.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) infinite; }

  @keyframes pulse-ring {
    0%        { box-shadow: 0 0 0 0 rgba(5, 150, 105, 0.5); }
    60%       { box-shadow: 0 0 0 8px rgba(5, 150, 105, 0); }
    100%      { box-shadow: 0 0 0 0 rgba(5, 150, 105, 0); }
  }
  .roadmap-pulse { animation: pulse-ring 1.6s cubic-bezier(0.25, 0.46, 0.45, 0.94) infinite; }

  /* Card 3 - Tools & Systems: stronger layer glow with lift */
  @keyframes layer-indigo {
