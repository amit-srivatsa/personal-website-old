---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Page Not Found - Amit Srivatsa"
  description="The page you're looking for doesn't exist."
  noindex={true}
>
  <section class="min-h-screen flex items-center justify-center bg-white px-6">
    <div class="text-center max-w-md">
      <p class="text-8xl font-black text-gray-100 mb-4 select-none">404</p>
      <h1 class="text-3xl font-bold text-gray-900 mb-4">Page not found</h1>
      <p class="text-gray-500 mb-8">
        This page doesn't exist or may have been moved.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 px-6 py-3 bg-orange-500 hover:bg-orange-600 text-white font-bold rounded-xl transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
        Back to home
      </a>
    </div>
  </section>
</BaseLayout>
