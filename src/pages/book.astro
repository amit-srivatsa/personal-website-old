---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Book a Consultation - Amit Srivatsa" description="Book a consultation with Amit Srivatsa to discuss your AI strategy, content marketing needs, or career growth." keywords="consultation, booking, AI strategy, content marketing, Amit Srivatsa">
  <section class="py-24 lg:py-32 relative overflow-hidden min-h-screen bg-white">
    <div class="absolute inset-0 bg-gradient-to-b from-white via-gray-50 to-white -z-20"></div>
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-gradient-to-br from-orange-100/40 to-yellow-100/40 rounded-full blur-3xl -z-10 translate-x-1/3 -translate-y-1/3"></div>

    <div class="max-w-7xl mx-auto px-6 sm:px-8">
      <div class="mb-12">
        <a href="/" class="inline-flex items-center text-sm font-semibold text-gray-500 hover:text-black mb-8 transition-colors group">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 transition-transform group-hover:-translate-x-1"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
          Back to Home
        </a>

        <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-gray-900 mb-6">
          Book a Consultation.
        </h1>
        <p class="text-xl text-gray-500 leading-relaxed max-w-2xl font-medium">
          Let's discuss your AI strategy, content marketing needs, or career growth.
          Select a time that works for you below.
        </p>
      </div>

      <div class="w-full bg-white rounded-3xl shadow-2xl shadow-gray-200/50 overflow-hidden ring-1 ring-gray-100">
        <iframe
          src="https://calendar.google.com/calendar/appointments/schedules/AcZssZ0J-z0?gv=true"
          style="border: 0;"
          width="100%"
          height="800"
          title="Book a Consultation"
        ></iframe>
      </div>
    </div>
  </section>
</BaseLayout>
