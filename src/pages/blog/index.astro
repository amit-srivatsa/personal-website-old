---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function readTime(body: string): string {
  const words = body.split(/\s+/).length;
  return `${Math.max(1, Math.ceil(words / 200))} min read`;
}

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---
<BaseLayout title="Blog - Amit Srivatsa" description="Read Amit Srivatsa's blog for insights on AI, marketing, and career development." keywords="blog, articles, AI, marketing, career, Amit Srivatsa">
  <div class="min-h-screen pt-32 pb-24 bg-white">
    <div class="max-w-7xl mx-auto px-6 sm:px-8">
      <div class="mb-16">
        <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-gray-900 mb-6">Writing.</h1>
        <p class="text-lg text-gray-500 font-medium max-w-2xl">
          Thoughts on the intersection of Marketing, AI, and the future of work.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <a href={`/blog/${post.data.category.toLowerCase().replace(/\s+/g, '-')}/${post.id.replace(/\.md$/, '')}/`} class="group cursor-pointer flex flex-col h-full">
            <div class="relative aspect-[4/3] overflow-hidden rounded-2xl mb-6 bg-gray-100">
              {post.data.image
                ? <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
                : <div class="w-full h-full bg-gradient-to-br from-gray-100 to-gray-200" />
              }
              <div class="absolute top-4 left-4 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-bold text-gray-900 uppercase tracking-wide">
                {post.data.category}
              </div>
            </div>
            <div class="flex-1">
              <div class="flex items-center gap-3 text-xs font-semibold text-gray-400 mb-3 uppercase tracking-wider">
                <span>{formatDate(post.data.date)}</span>
                <span>&bull;</span>
                <span>{readTime(post.body || '')}</span>
              </div>
              <h2 class="text-2xl font-bold text-gray-900 mb-3 group-hover:text-blue-600 transition-colors leading-tight">
                {post.data.title}
              </h2>
              <p class="text-gray-500 leading-relaxed line-clamp-3">
                {post.data.excerpt || (post.body || '').substring(0, 150) + '...'}
              </p>
            </div>
            <div class="mt-6 flex items-center text-sm font-bold text-gray-900">
              Read Article &rarr;
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
